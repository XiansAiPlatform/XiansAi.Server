# XiansAi Server Environment Configuration - DEVELOPMENT
# This file contains actual development values from appsettings.Development.json
# Uses standard .NET Core environment variable naming: SectionName__PropertyName

# ====================
# GENERAL SETTINGS
# ====================
CONFIG_NAME=Agentri.ai
ASPNETCORE_ENVIRONMENT=Production
SERVICE_TYPE=--all
ASPNETCORE_URLS=http://+:8080

# ====================
# SEED DATA SETTINGS
# ====================
SeedData__Enabled=true
SeedData__CreateDefaultTenant=true
SeedData__DefaultTenant__TenantId=default
SeedData__DefaultTenant__Name=Default Tenant
SeedData__DefaultTenant__Domain=default.xiansai.com

# ====================
# DATABASE SETTINGS
# ====================
MongoDB__ConnectionString=mongodb://...
MongoDB__DatabaseName=xians

# ====================
# TEMPORAL WORKFLOW ENGINE
# ====================
# -- STAGING --
# Temporal__CertificateBase64=
# Temporal__PrivateKeyBase64=
# Temporal__FlowServerUrl=tenant-99x.ozqzb.tmprl.cloud:7233
# Temporal__FlowServerNamespace=tenant-99x.ozqzb

# -- Local Docker --
#Temporal__FlowServerUrl=localhost:7233
Temporal__FlowServerUrl=host.docker.internal:7233
Temporal__FlowServerNamespace=default

# ====================
# CERTIFICATES
# ====================
Certificates__AppServerPfxBase64=
Certificates__AppServerCertPassword=password

# ====================
# CACHING
# ====================
Cache__Provider=memory
Cache__Redis__ConnectionString=

# ====================
# AI/LLM SETTINGS
# ====================
Llm__Provider=OpenAI
Llm__Model=gpt-4o-mini
Llm__ApiKey=

# ====================
# EMAIL SETTINGS
# ====================
Email__Provider=console
Email__Azure__ConnectionString=
Email__Azure__SenderEmail=

# ====================
# AUTHENTICATION - Keycloak
# ====================
AuthProvider__Provider=Keycloak
Keycloak__AuthServerUrl=http://localhost:18080/
Keycloak__Realm=xiansai
Keycloak__ValidIssuer=http://localhost:18080/realms/xiansai


# ====================
# AUTHENTICATION - Auth0
# ====================
# AuthProvider__Provider=Auth0
# Auth0__Domain=xiansai-prod.eu.auth0.com
# Auth0__Audience=https://xians.ai/api
# Auth0__ManagementApi__ClientId=
# Auth0__ManagementApi__ClientSecret=

# ====================
# CORS SETTINGS (JSON array format)
# Use index notation for arrays: __0, __1, __2, etc.
# ====================
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=https://app.agentri.ai

# ====================
# WEBSOCKETS
# ====================
WebSockets__Enabled=true

# ====================
# ENCRYPTION
# ====================
EncryptionKeys__BaseSecret=your-encryption-key
EncryptionKeys__UniqueSecrets__ConversationMessageKey=mysecretkey2
EncryptionKeys__UniqueSecrets__TenantOidcSecretKey=mysecretkey3
EncryptionKeys__UniqueSecrets__AppIntegrationSecretKey=mysecretkey4
# Legacy SecretVault key. Only required to decrypt rows written before the
# pluggable Secret Store provider was introduced. New rows use a per-record key
# derived from the secret id, so this can be removed after migration.
EncryptionKeys__UniqueSecrets__SecretVaultKey=mysecretkey5

# ====================
# SECRET STORE (Secret Vault backend)
# ====================
# Active provider: 'database' (default, AES-256-GCM in MongoDB) or 'azurekeyvault'.
SecretStore__Provider=database
# Required when SecretStore__Provider=azurekeyvault
SecretStore__AzureKeyVault__VaultUri=
# Optional. Prepended to each Key Vault secret name. Default: xians-
SecretStore__AzureKeyVault__SecretNamePrefix=xians-

# ====================
# LOGGING (Optional - can be left in appsettings.Development.json)
# ====================
Logging__LogLevel__Default=Debug
Logging__LogLevel__Microsoft.AspNetCore=Warning

# ====================
# USAGE EVENTS 
# ====================
UsageEvents__RecordUsageEvents=true

# ====================
# OPENTELEMETRY (Optional)
# ====================
# Set Enabled=true and provide an OtlpEndpoint to activate telemetry export.
# Development (Aspire Dashboard): http://aspire-dashboard:18889
# Production (OTEL Collector):    http://otel-collector:4317
OpenTelemetry__Enabled=false
OpenTelemetry__ServiceName=XiansAi.Server
OpenTelemetry__OtlpEndpoint=http://aspire-dashboard:18889
# Emit user identity fields (tenant.user, tenant.user_type, tenant.user_roles) as span attributes.
# OFF by default — these are PII. Enable only in trusted, internal-only observability environments.
#OpenTelemetry__IncludeUserIdentity=false
# Tag name used for tenant identity on all spans and log records (default: tenant.id).
# Override when your observability backend expects a different convention (e.g. custom.tenant_id).
#OPENTELEMETRY_TENANT_TAG_NAME=tenant.id
# Comma-separated list of MongoDB commands to suppress from traces.
# When not set, all commands are monitored. Uncomment and adjust as needed.
#OpenTelemetry__MongoDB__ExcludedCommands=getMore,ping
# Legacy key (supported for backward compatibility):
#OPENTELEMETRY_MONGODB_EXCLUDED_COMMANDS=getMore,ping
# Capture raw MongoDB query documents as span attributes (filter values, $match fields, etc.).
# OFF by default — query documents can contain tenant data or PII. Enable only in trusted environments.
#OpenTelemetry__MongoDB__CaptureCommandText=false
# Legacy key (supported for backward compatibility):
#OPENTELEMETRY_MONGODB_CAPTURE_COMMAND_TEXT=false
