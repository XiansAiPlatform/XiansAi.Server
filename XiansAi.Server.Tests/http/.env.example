# Local-only environment for the *.http test scratchpads.
#
# Copy this file to `.env` (already gitignored via the repo .gitignore allow-list)
# and fill in your personal SysAdmin API key. NEVER commit a real key.
#
#   cp XiansAi.Server.Tests/http/.env.example XiansAi.Server.Tests/http/.env
#
# Reference in *.http files via:
#   @apiKey = {{$processEnv ADMIN_API_KEY}}
#
# JetBrains HTTP Client users: alternatively define ADMIN_API_KEY in
# `http-client.private.env.json` (also gitignored) instead of using .env.

ADMIN_API_KEY=
